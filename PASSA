<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Passa — Bootcamp IELTS intensivo de 20 horas en 2 semanas. Metodología de examinador real. Máximo 5 estudiantes. Garantía de resultado. Colombia.">
<meta property="og:title" content="Passa — Bootcamp IELTS Colombia">
<meta property="og:description" content="Prepárate con quien conoce el examen por dentro. 11 años de experiencia. Garantía de resultado.">
<title>Passa — Bootcamp IELTS Colombia</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0d2137;
    --navy-mid: #15304f;
    --teal: #009b8d;
    --teal-light: #00c4b3;
    --cream: #f5f0e8;
    --cream-dark: #ede6d8;
    --white: #ffffff;
    --text-dark: #0d2137;
    --text-mid: #3a5068;
    --text-light: #6b8299;
    --warn: #e85d24;
    --warn-light: #fff1eb;
    --gold: #c9974a;
    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, sans-serif;
    --radius: 12px;
    --radius-lg: 20px;
    --shadow: 0 4px 32px rgba(13,33,55,0.10);
    --shadow-lg: 0 12px 60px rgba(13,33,55,0.16);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    color: var(--text-dark);
    background: var(--cream);
    overflow-x: hidden;
    font-size: 16px;
    line-height: 1.7;
  }

  /* ── NAV ─────────────────────────────────────── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(13,33,55,0.95);
    backdrop-filter: blur(12px);
    padding: 0 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.5px;
    text-decoration: none;
  }
  .nav-logo span { color: var(--teal-light); }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }
  .nav-links a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: 14px;
    font-weight: 400;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }

  .nav-cta {
    background: var(--teal);
    color: var(--white) !important;
    padding: 8px 20px;
    border-radius: 40px;
    font-weight: 500 !important;
    font-size: 13px !important;
    transition: background 0.2s, transform 0.15s !important;
  }
  .nav-cta:hover { background: var(--teal-light) !important; transform: translateY(-1px); }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: white; border-radius: 2px; transition: all 0.3s; }

  /* ── HERO ────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    background: var(--navy);
    display: flex;
    align-items: center;
    padding: 100px 5% 80px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(0,155,141,0.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -100px; left: -100px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(0,155,141,0.09) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,196,179,0.12);
    border: 1px solid rgba(0,196,179,0.25);
    color: var(--teal-light);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 40px;
    margin-bottom: 24px;
  }
  .hero-eyebrow::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--teal-light);
    border-radius: 50%;
    display: inline-block;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(42px, 5vw, 68px);
    font-weight: 700;
    color: var(--white);
    line-height: 1.08;
    letter-spacing: -1.5px;
    margin-bottom: 24px;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--teal-light);
  }

  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 480px;
    font-weight: 300;
  }

  .hero-btns {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--teal);
    color: var(--white);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 28px;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(0,155,141,0.35);
  }
  .btn-primary:hover {
    background: var(--teal-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,155,141,0.45);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: rgba(255,255,255,0.75);
    font-size: 15px;
    font-weight: 400;
    padding: 14px 24px;
    border-radius: 50px;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    border-color: rgba(255,255,255,0.5);
    color: white;
  }

  .hero-stats {
    display: flex;
    gap: 24px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .hero-stat { flex: 1; }
  .hero-stat-val {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
    margin-bottom: 4px;
  }
  .hero-stat-val span { color: var(--teal-light); }
  .hero-stat-lbl {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    font-weight: 300;
    line-height: 1.4;
  }

  /* Hero card */
  .hero-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    padding: 32px;
    backdrop-filter: blur(12px);
    position: relative;
  }

  .urgency-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--warn);
    color: white;
    font-size: 11px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 40px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .hero-card h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 6px;
    letter-spacing: -0.3px;
  }
  .hero-card p {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 24px;
    font-weight: 300;
  }

  .card-feature {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
  }
  .card-feature:last-of-type { margin-bottom: 24px; }
  .cf-icon {
    width: 34px;
    height: 34px;
    background: rgba(0,155,141,0.15);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .cf-text strong {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 1px;
  }
  .cf-text span {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    font-weight: 300;
  }

  .price-display {
    background: rgba(0,155,141,0.12);
    border: 1px solid rgba(0,196,179,0.2);
    border-radius: var(--radius);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .price-main {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--white);
  }
  .price-note {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    text-align: right;
    line-height: 1.5;
  }
  .price-launch {
    font-size: 11px;
    color: var(--teal-light);
    margin-bottom: 16px;
    font-weight: 400;
  }

  .btn-wa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #25d366;
    color: white;
    font-size: 15px;
    font-weight: 500;
    padding: 14px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    width: 100%;
  }
  .btn-wa:hover { background: #1ebe59; transform: translateY(-1px); }

  .wa-icon { width: 20px; height: 20px; }

  .spots-left {
    text-align: center;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin-top: 12px;
  }
  .spots-left strong { color: var(--warn); font-weight: 500; }

  /* ── TRUST BAR ───────────────────────────────── */
  .trust-bar {
    background: var(--navy-mid);
    padding: 18px 5%;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .trust-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    font-weight: 300;
  }
  .trust-item strong { color: rgba(255,255,255,0.85); font-weight: 500; }
  .trust-dot { color: rgba(255,255,255,0.2); }

  /* ── SECTIONS ────────────────────────────────── */
  section { padding: 96px 5%; }
  .section-inner { max-width: 1100px; margin: 0 auto; }

  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 12px;
  }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.12;
    letter-spacing: -1px;
    margin-bottom: 16px;
  }
  .section-h2 em { font-style: italic; color: var(--teal); }
  .section-sub {
    font-size: 17px;
    color: var(--text-mid);
    font-weight: 300;
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 56px;
  }

  /* ── PAIN SECTION ────────────────────────────── */
  .pain-section { background: var(--cream); }
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  .pain-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 28px;
    border: 1px solid rgba(13,33,55,0.06);
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .pain-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .pain-emoji { font-size: 28px; margin-bottom: 16px; }
  .pain-card h4 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 8px;
    letter-spacing: -0.3px;
  }
  .pain-card p {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.65;
    font-weight: 300;
  }

  /* ── DIFFERENTIATORS ─────────────────────────── */
  .diff-section { background: var(--navy); }
  .diff-section .section-h2 { color: var(--white); }
  .diff-section .section-sub { color: rgba(255,255,255,0.55); }
  .diff-section .section-label { color: var(--teal-light); }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .diff-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: border-color 0.2s, background 0.2s;
  }
  .diff-card:hover {
    border-color: rgba(0,196,179,0.3);
    background: rgba(0,155,141,0.06);
  }
  .diff-num {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 300;
    color: var(--teal-light);
    margin-bottom: 12px;
    letter-spacing: 0.05em;
  }
  .diff-card h4 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 10px;
    letter-spacing: -0.3px;
    line-height: 1.2;
  }
  .diff-card p {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    font-weight: 300;
  }

  /* ── PROGRAM ─────────────────────────────────── */
  .program-section { background: var(--cream-dark); }
  .program-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .program-weeks { display: flex; flex-direction: column; gap: 12px; }
  .week-block {
    background: var(--white);
    border-radius: var(--radius);
    padding: 20px 24px;
    border: 1px solid rgba(13,33,55,0.07);
    display: flex;
    gap: 18px;
    align-items: flex-start;
    box-shadow: 0 2px 12px rgba(13,33,55,0.06);
  }
  .week-tag {
    background: var(--navy);
    color: var(--teal-light);
    font-size: 11px;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 40px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
    letter-spacing: 0.04em;
  }
  .week-content h5 {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-dark);
    margin-bottom: 3px;
  }
  .week-content p {
    font-size: 13px;
    color: var(--text-mid);
    font-weight: 300;
    line-height: 1.55;
  }

  .program-aside { position: sticky; top: 80px; }
  .program-aside h3 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--text-dark);
    letter-spacing: -0.5px;
    margin-bottom: 24px;
    line-height: 1.2;
  }
  .program-aside h3 em { font-style: italic; color: var(--teal); }

  .stat-blocks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 24px;
  }
  .stat-block {
    background: var(--white);
    border-radius: var(--radius);
    padding: 20px;
    border: 1px solid rgba(13,33,55,0.07);
    text-align: center;
  }
  .stat-block-val {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-block-val span { color: var(--teal); }
  .stat-block-lbl {
    font-size: 12px;
    color: var(--text-light);
    font-weight: 300;
    line-height: 1.4;
  }

  .includes-list { list-style: none; }
  .includes-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(13,33,55,0.07);
    font-size: 14px;
    color: var(--text-mid);
    font-weight: 300;
    line-height: 1.5;
  }
  .includes-list li:last-child { border-bottom: none; }
  .includes-list li::before {
    content: '✓';
    color: var(--teal);
    font-weight: 500;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── GUARANTEE ───────────────────────────────── */
  .guarantee-section { background: var(--cream); }
  .guarantee-inner {
    background: var(--navy);
    border-radius: 24px;
    padding: 56px 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .guarantee-inner::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(0,155,141,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .guarantee-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal-light);
    font-weight: 500;
    margin-bottom: 14px;
  }
  .guarantee-h {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.8px;
    margin-bottom: 16px;
  }
  .guarantee-h em { font-style: italic; color: var(--teal-light); }
  .guarantee-text {
    font-size: 15px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 0;
  }
  .conditions-title {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 16px;
  }
  .condition-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 14px;
  }
  .condition-item:last-child { margin-bottom: 0; }
  .cond-arrow {
    color: var(--teal-light);
    font-size: 14px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .condition-item p {
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    line-height: 1.55;
    font-weight: 300;
  }

  /* ── PRICING ─────────────────────────────────── */
  .pricing-section { background: var(--cream-dark); }
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: 20px;
    align-items: start;
  }
  .pricing-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 28px;
    border: 1px solid rgba(13,33,55,0.08);
    box-shadow: var(--shadow);
  }
  .pricing-card.featured {
    background: var(--navy);
    border-color: transparent;
    box-shadow: var(--shadow-lg);
    position: relative;
  }
  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--teal);
    color: white;
    font-size: 11px;
    font-weight: 500;
    padding: 4px 16px;
    border-radius: 40px;
    white-space: nowrap;
  }
  .pc-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 8px;
  }
  .featured .pc-label { color: rgba(255,255,255,0.45); }
  .pc-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 4px;
    letter-spacing: -0.3px;
  }
  .featured .pc-name { color: var(--white); }
  .pc-price {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 700;
    color: var(--navy);
    margin: 12px 0 2px;
    letter-spacing: -1px;
  }
  .featured .pc-price { color: var(--white); }
  .pc-period {
    font-size: 12px;
    color: var(--text-light);
    margin-bottom: 20px;
    font-weight: 300;
  }
  .featured .pc-period { color: rgba(255,255,255,0.4); }
  .pc-list { list-style: none; margin-bottom: 24px; }
  .pc-list li {
    font-size: 13px;
    color: var(--text-mid);
    padding: 8px 0;
    border-bottom: 1px solid rgba(13,33,55,0.06);
    display: flex;
    gap: 8px;
